# Tinker — environment variable reference
# Copy this file to .env and fill in the values for your environment.
# .env is never committed to the repository.

# ---------------------------------------------------------------------------
# Instance identity
# ---------------------------------------------------------------------------

# The public domain name for this instance. Used in ActivityPub URIs,
# WebFinger responses, and all federation links. No scheme, no trailing slash.
TINKER_DOMAIN=example.com

# The ActivityPub actor username. Appears in the actor URI
# (https://<domain>/<username>) and the fediverse handle (@<username>@<domain>).
TINKER_USERNAME=yourname

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Secret key used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Changing this value invalidates all existing sessions.
TINKER_SECRET_KEY=replace-with-a-long-random-string

# Plaintext admin password. On first startup, Tinker hashes this with argon2
# and stores the hash in the database, then ignores this value on subsequent
# starts. Once set, change the password through the admin settings UI.
TINKER_ADMIN_PASSWORD=replace-with-a-strong-password

# ---------------------------------------------------------------------------
# Storage paths
# ---------------------------------------------------------------------------

# Path to the SQLite database file, relative to the project root.
TINKER_DB_PATH=db/tinker.db

# Path to the directory where uploaded media and cached remote avatars are
# stored. Can be absolute or relative to the project root.
TINKER_MEDIA_PATH=media/
